{
  "name": "utils",
  "private": true,
  "version": "0.0.12",
  "description": "Monorepo for shared utilities across IM Apps projects",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/imapps/utils.git"
  },
  "packageManager": "bun@latest",
  "lint-staged": {
    "*.{ts,mts,cts,json}": [
      "biome check --fix --unsafe"
    ]
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "clean": "bun run --filter '*' clean",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "prepare": "husky",
    "release": "bunx semantic-release",
    "release:dry": "bunx semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@imapps/biome-config": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.8",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
