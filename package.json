{
  "name": "im-apps-utils",
  "private": true,
  "version": "0.0.12",
  "description": "Monorepo for shared utilities across IM Apps projects",
  "packageManager": "yarn@4.9.2",
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "yarn workspace @imapps/eslint-config build",
      "eslint --fix"
    ]
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -At run build",
    "clean": "yarn workspaces foreach -A run clean",
    "lint": "yarn workspace @imapps/eslint-config build && eslint . --ext .ts,.mts,.cts",
    "lint:fix": "yarn workspace @imapps/eslint-config build && eslint . --ext .ts,.mts,.cts --fix",
    "prelint": "yarn workspace @imapps/eslint-config build",
    "prelint:fix": "yarn workspace @imapps/eslint-config build",
    "prepare": "husky",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@imapps/eslint-config": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.8",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "eslint": "^9.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.0",
    "semantic-release-yarn": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
