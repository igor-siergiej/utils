{
  "name": "@igor-siergiej/api-utils",
  "version": "0.4.5",
  "description": "Shared API utilities for Node services",
  "author": "igor-siergiej",
  "license": "AGPL-3.0 license",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/igor-siergiej/utils"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.mjs",
      "require": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf build",
    "prepack": "yarn clean && yarn build",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "minio": "^8.0.0",
    "mongodb": "^6.19.0"
  }
}
